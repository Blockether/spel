{
  "version": 1,
  "cases": [
    {
      "id": "orchestrator-core-opencode",
      "description": "Scaffold core OpenCode agents and evaluate generated orchestrator contracts.",
      "args": [
        "init-agents",
        "--ns",
        "spel.evals",
        "--loop=opencode",
        "--only=core",
        "--no-tests"
      ],
      "checks": [
        {
          "id": "orchestrator_exists",
          "kind": "exists",
          "path": ".opencode/agents/spel-orchestrator.md",
          "required": true,
          "why": "The orchestrator must be scaffolded for core agent setups."
        },
        {
          "id": "spel_skill_exists",
          "kind": "exists",
          "path": ".opencode/skills/spel/SKILL.md",
          "required": true,
          "why": "Generated agents need the spel skill available in the workspace."
        },
        {
          "id": "agent_common_ref_exists",
          "kind": "exists",
          "path": ".opencode/skills/spel/references/AGENT_COMMON.md",
          "required": true,
          "why": "Shared operational guidance must be scaffolded for downstream agents."
        },
        {
          "id": "orchestrator_loads_spel_skill",
          "kind": "contains",
          "path": ".opencode/agents/spel-orchestrator.md",
          "value": "Load the `spel` skill before any action.",
          "required": true,
          "why": "The orchestrator should explicitly load the spel skill."
        },
        {
          "id": "orchestrator_artifact_first",
          "kind": "contains",
          "path": ".opencode/agents/spel-orchestrator.md",
          "value": "Artifact-first coordination",
          "required": true,
          "why": "The orchestrator should enforce artifact-first delivery."
        },
        {
          "id": "orchestrator_handoff_paths",
          "kind": "all_contains",
          "path": ".opencode/agents/spel-orchestrator.md",
          "values": [
            "orchestration/automation-pipeline.json",
            "orchestration/qa-pipeline.json",
            "orchestration/test-pipeline.json",
            "orchestration/discovery-pipeline.json"
          ],
          "required": true,
          "why": "The orchestrator should own all pipeline handoff contracts."
        },
        {
          "id": "no_seed_tests_when_no_tests",
          "kind": "absent",
          "path": "test-e2e/spel/evals/e2e/seed_test.clj",
          "required": true,
          "why": "No test seed should be created when --no-tests is used."
        },
        {
          "id": "start_here_doc_exists",
          "kind": "exists",
          "path": ".opencode/skills/spel/references/START_HERE.md",
          "required": false,
          "why": "A generated START_HERE doc would improve agent discoverability."
        },
        {
          "id": "capabilities_manifest_exists",
          "kind": "exists",
          "path": ".opencode/skills/spel/references/CAPABILITIES.md",
          "required": false,
          "why": "A compact capabilities manifest would reduce tool/skill omission."
        }
      ]
    },
    {
      "id": "automation-opencode",
      "description": "Scaffold automation agents and evaluate workflow/session guidance.",
      "args": [
        "init-agents",
        "--ns",
        "spel.evals",
        "--loop=opencode",
        "--only=automation",
        "--force",
        "--no-tests"
      ],
      "checks": [
        {
          "id": "explorer_exists",
          "kind": "exists",
          "path": ".opencode/agents/spel-explorer.md",
          "required": true,
          "why": "Automation scaffolding should generate the explorer agent."
        },
        {
          "id": "automator_exists",
          "kind": "exists",
          "path": ".opencode/agents/spel-automator.md",
          "required": true,
          "why": "Automation scaffolding should generate the automator agent."
        },
        {
          "id": "automation_workflow_exists",
          "kind": "exists",
          "path": ".opencode/prompts/spel-automation-workflow.md",
          "required": true,
          "why": "Automation scaffolding should include the workflow prompt."
        },
        {
          "id": "automation_workflow_cdp_policy",
          "kind": "contains",
          "path": ".opencode/prompts/spel-automation-workflow.md",
          "value": "CDP ownership and port policy",
          "required": true,
          "why": "Automation workflow should document single-owner CDP policy."
        },
        {
          "id": "automation_workflow_session_isolation",
          "kind": "contains",
          "path": ".opencode/prompts/spel-automation-workflow.md",
          "value": "Sessions never overlap.",
          "required": true,
          "why": "Automation workflow should declare non-overlapping agent sessions."
        }
      ]
    },
    {
      "id": "discovery-opencode",
      "description": "Scaffold discovery agents and evaluate product-analysis artifacts.",
      "args": [
        "init-agents",
        "--ns",
        "spel.evals",
        "--loop=opencode",
        "--only=discovery",
        "--force",
        "--no-tests"
      ],
      "checks": [
        {
          "id": "product_analyst_exists",
          "kind": "exists",
          "path": ".opencode/agents/spel-product-analyst.md",
          "required": true,
          "why": "Discovery scaffolding should generate the product analyst agent."
        },
        {
          "id": "discovery_workflow_exists",
          "kind": "exists",
          "path": ".opencode/prompts/spel-discovery-workflow.md",
          "required": true,
          "why": "Discovery prompt should be scaffolded when --only=discovery is used."
        },
        {
          "id": "product_discovery_ref_exists",
          "kind": "exists",
          "path": ".opencode/skills/spel/references/PRODUCT_DISCOVERY.md",
          "required": true,
          "why": "Product schema docs must be available to the analyst."
        },
        {
          "id": "discovery_workflow_outputs",
          "kind": "all_contains",
          "path": ".opencode/prompts/spel-discovery-workflow.md",
          "values": [
            "product-spec.json",
            "product-faq.json",
            "spel-report.html",
            "spel-report.md"
          ],
          "required": true,
          "why": "Discovery workflow should request all expected product-analysis artifacts."
        },
        {
          "id": "analyst_priority_refs",
          "kind": "all_contains",
          "path": ".opencode/agents/spel-product-analyst.md",
          "values": [
            "AGENT_COMMON.md",
            "PRODUCT_DISCOVERY.md",
            "EVAL_GUIDE.md",
            "SELECTORS_SNAPSHOTS.md"
          ],
          "required": true,
          "why": "The product analyst should declare its critical refs explicitly."
        },
        {
          "id": "discovery_start_here_doc_exists",
          "kind": "exists",
          "path": ".opencode/skills/spel/references/START_HERE.md",
          "required": false,
          "why": "Discovery agents would benefit from a shorter generated entrypoint doc."
        }
      ]
    },
    {
      "id": "orchestrator-core-claude",
      "description": "Scaffold core Claude agents and evaluate equivalent orchestrator wiring.",
      "args": [
        "init-agents",
        "--ns",
        "spel.evals",
        "--loop=claude",
        "--only=core",
        "--force",
        "--no-tests"
      ],
      "checks": [
        {
          "id": "claude_orchestrator_exists",
          "kind": "exists",
          "path": ".claude/agents/spel-orchestrator.md",
          "required": true,
          "why": "Claude loop should also generate the orchestrator agent."
        },
        {
          "id": "claude_skill_exists",
          "kind": "exists",
          "path": ".claude/docs/spel/SKILL.md",
          "required": true,
          "why": "Claude loop should receive the spel skill docs."
        },
        {
          "id": "claude_agent_common_ref_exists",
          "kind": "exists",
          "path": ".claude/docs/spel/references/AGENT_COMMON.md",
          "required": true,
          "why": "Claude loop needs the same common reference docs."
        },
        {
          "id": "claude_orchestrator_skill_load",
          "kind": "contains",
          "path": ".claude/agents/spel-orchestrator.md",
          "value": ".claude/docs/spel/SKILL.md` before any action.",
          "required": true,
          "why": "The generated Claude orchestrator should still declare skill loading."
        },
        {
          "id": "claude_start_here_doc_exists",
          "kind": "exists",
          "path": ".claude/docs/spel/references/START_HERE.md",
          "required": false,
          "why": "Claude loop also lacks a short discoverability index today."
        }
      ]
    }
  ]
}
